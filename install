#INSTALLING PURE DEBIAN 13 WITH I3 WINDOW MANAGER FROM TTY
#WITH SEVARAL COLOR-SCHEMES

Phase 1 — ENABLE SUDO 
  su -

  apt install sudo

  usermod -aG sudo YOUR_USERNAME

Phase 2 — Enable contrib/non-free repos

Edit:

  sudo nano /etc/apt/sources.list

  Make sure Debian 13 repos contain:

  main contrib non-free-firmware

UPDATES:

  sudo apt update && sudo apt full-upgrade -y

Reboot:
  sudo reboot

PHASE 3 — Install Build Tools

  sudo apt install -y build-essential git curl wget unzip cmake meson ninja-build pkg-config

PHASE 4 — Install Xorg

  sudo apt install xorg xorg-dev xinput xbacklight xdotool dbus-x11

PHASE 5 — Install i3

  sudo apt install i3 sxhkd

Verify:
  i3 --version
  sxhkd -v

PHASE 6 — Install UI Components
  sudo apt install polybar rofi dunst picom feh

PHASE 7 — File Manager

  sudo apt install thunar thunar-volman thunar-archive-plugin gvfs-backends gvfs

PHASE 8 — Audio
  sudo apt install pipewire-audio pamixer pulsemixer pavucontrol

  Used by: scripts/changevolume

PHASE 9 — Power & Network

  sudo apt install network-manager-gnome lxpolkit xfce4-power-manager acpi acpid

Enable:
  sudo systemctl enable acpid

PHASE 10 — Utilities
sudo apt install flameshot qimgv fd-find xclip xsel

PHASE 11 — Fonts
RUN:
  mkdir -p ~/.local/share/fonts
  
  cd ~/.local/share/fonts

  wget https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip

  unzip JetBrainsMono.zip

  fc-cache -fv

Phase 12 — Install Ghostty
DEPENDENCIES:
  sudo apt install zig libgtk-4-dev libadwaita-1-dev blueprint-compiler

INSTALL GHOSTTY:
  git clone https://github.com/ghostty-org/ghostty

  cd ghostty

  zig build -p ~/.local

Phase 13 — Install Brave

sudo curl -fsSLo \
/usr/share/keyrings/brave-browser-archive-keyring.gpg \
https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg

echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg] \
https://brave-browser-apt-release.s3.brave.com/ stable main" | \
sudo tee /etc/apt/sources.list.d/brave-browser-release.list

  sudo apt update

  sudo apt install brave-browser

PHASE 14 — Install Zsh

  sudo apt install -y zsh

Set default shell:
  chsh -s $(which zsh)

Log out and back in.

PHASE 15 — Install Eza
Debian 13 should have:

  sudo apt install eza

Verify:
  eza --version

PHASE 16 — Display Manager

  sudo apt install -y lightdm lightdm-gtk-greeter

Enable:
  sudo systemctl enable lightdm

PHASE 17 — Copy Config Files

Create:

mkdir -p ~/.config

Copy from the repo:

i3/

to:

~/.config/i3/

PHASE 18 — Make Scripts Executable

  chmod +x ~/.config/i3/scripts/*

PHASE 19 — Install GTK Themes & Icons

The repo expects:

Gruvbox
Nord
Catppuccin
Dracula
Everforest
Github Dark
TokyoNight

You can install them manually later.

For now:

sudo apt install -y nwg-look

which lets you switch GTK themes visually.

PHASE 20 — Install Neovim From Source

git clone https://github.com/neovim/neovim.git
cd neovim
make CMAKE_BUILD_TYPE=Release
sudo make install

Verify:

nvim --version

PHASE 21 - BLUETOOTH
  sudo apt install blueman bluez

PHASE 22 - AUTOTILING 

  sudo apt install python3-pip
  pip install autotiling

Phase 23 — First Start

From TTY:

startx

or reboot:

sudo reboot

