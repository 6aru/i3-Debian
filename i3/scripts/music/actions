#!/usr/bin/env bash

[ -z "$song" ] && exit

choice=$(printf \
"‚Ė∂ Play\n‚Ź≠ Play Next\n‚ěē Queue\n‚Ě§ÔłŹ Favorite" \
| rofi -dmenu -p "$song")

case "$choice" in

    "‚Ė∂ Play")
        mpc clear
        mpc search title "$song" | head -n1 | xargs -r mpc add
        mpc play
        ;;

    "‚Ź≠ Play Next")
        file=$(mpc search title "$song" | head -n1)
        [ -z "$file" ] && exit
        pos=$(mpc status | awk '/#/{gsub("#","",$2); print $2}')
        mpc insert "$file"
        ;;
   
    "‚ěē Queue")
        mpc search title "$song" | head -n1 | xargs -r mpc add
        ;;

    "‚Ě§ÔłŹ Favorite")
        grep -Fxq "$song" ~/.config/mpd/favorites.txt || \
        echo "$song" >> ~/.config/mpd/favorites.txt
        ;;

esac
